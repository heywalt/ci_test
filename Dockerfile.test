# Dockerfile for running tests, linters, and formatters in CI.
# Based on the same Elixir/OTP/Debian versions as the production Dockerfile.
ARG ELIXIR_VERSION=1.18.4
ARG OTP_VERSION=26.2.5.13
ARG DEBIAN_VERSION=bullseye-20250630-slim

ARG BUILDER_IMAGE="hexpm/elixir:${ELIXIR_VERSION}-erlang-${OTP_VERSION}-debian-${DEBIAN_VERSION}"

FROM ${BUILDER_IMAGE}

# Install build dependencies
RUN apt-get update -y && apt-get install -y build-essential git curl \
    && apt-get clean && rm -f /var/lib/apt/lists/*_*

WORKDIR /app

ARG OBAN_LICENSE_KEY

# Install Hex and Rebar
RUN mix do local.hex --force, local.rebar --force

# Add Oban private repo
RUN mix hex.repo add oban https://getoban.pro/repo \
    --fetch-public-key SHA256:4/OSKi0NRF91QVVXlGAhb/BIMLnK8NHcx/EWs+aIWPc \
    --auth-key $OBAN_LICENSE_KEY

# Copy dependency manifests first for Docker layer caching.
# apps.mix.tar.gz is generated by bin/package and contains apps/*/mix.exs.
ADD apps.mix.tar.gz .
COPY mix.exs mix.lock .coverignore ./
COPY config/config.exs config/test.exs config/dev.exs config/

# Get deps for all environments (includes dev-only tools like credo)
RUN mix deps.get

# Compile deps for test env (primary)
ENV MIX_ENV=test
RUN mix deps.compile --skip-umbrella-children

# Also compile deps for dev env (needed for credo, dialyxir)
RUN MIX_ENV=dev mix deps.compile --skip-umbrella-children

# Copy source code and formatter config
COPY .formatter.exs ./
COPY apps ./apps

# Compile the project for test env with warnings as errors
RUN mix compile --warnings-as-errors

# Pre-compile for dev env so credo can run without recompilation
RUN MIX_ENV=dev mix compile

CMD ["mix", "test"]
